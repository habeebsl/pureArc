# Core service wiring
PUREARC_API_BASE_URL=http://127.0.0.1:8000

# Runtime controls
# Set to 1 to run main.py alongside API, 0 to run API only
PUREARC_RUN_MAIN=1
# Camera index (e.g. 0) or absolute video path
PUREARC_VIDEO_SOURCE=0
# 1 enables H.264 output rendering via ffmpeg, 0 disables it
PUREARC_SAVE_OUTPUT=0

# Optional API publisher identity
PUREARC_API_USER_ID=local-user
PUREARC_API_DEVICE=cpu-droplet

# Live coach agent (optional)
PUREARC_LIVE_AGENT_URL=
PUREARC_LIVE_AGENT_KEY=
PUREARC_LIVE_AGENT_TIMEOUT_SECONDS=8

# Replay coach agent (optional)
PUREARC_REPLAY_AGENT_URL=
PUREARC_REPLAY_AGENT_KEY=
PUREARC_REPLAY_AGENT_TIMEOUT_SECONDS=12

# YouTube drill link function (optional)
PUREARC_YT_FUNCTION_URL=
PUREARC_YT_TOPIC=basketball shooting drills
PUREARC_YT_TIMEOUT_SECONDS=8
